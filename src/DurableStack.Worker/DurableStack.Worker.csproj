<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\DurableStack.AspNetCore\DurableStack.AspNetCore.csproj" />
    <ProjectReference Include="..\DurableStack.Core\DurableStack.Core.csproj" />
    <ProjectReference Include="..\DurableStack.MySql\DurableStack.MySql.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackageId>DurableStack.Worker</PackageId>
    <VersionPrefix>0.1.0</VersionPrefix>
    <VersionSuffix>beta.1</VersionSuffix>
    <Authors>DurableStack</Authors>
    <Company>DurableStack</Company>
    <Description>Worker service hosting integration for DurableStack durable jobs.</Description>
    <PackageTags>durable jobs;scheduler;background jobs;workerservice;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/durablestackhq/durablestack-dotnet</RepositoryUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <PackageReadmeFile>PACKAGE-README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\PACKAGE-README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
