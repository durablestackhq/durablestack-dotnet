{
  "ConnectionStrings": {
    "DurableStack": "Server=localhost;Database=durable_stack;Integrated Security=True;TrustServerCertificate=true"
  },
  "DurableStack": {
    "StorageProvider": "SqlServer",
    "DatabaseTablePrefix": "Acme_",
    "Eventing": {
      "TenantId": "example-tenant-dev",
      "ServiceName": "AspNetCoreSqlServerExample.Dev"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
